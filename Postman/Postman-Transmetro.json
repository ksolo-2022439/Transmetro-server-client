              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"CUI\": \"1234567890123\",\n  \"Email\": \"usuario@ejemplo.com\",\n  \"Password\": \"MiPasswordSeguro123\"\n}"
                },
